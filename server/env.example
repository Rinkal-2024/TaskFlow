# ========================================
# MERN Stack Task Manager - Environment Variables
# ========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/task-manager
MONGODB_URI_TEST=mongodb://localhost:27017/task-manager-test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:3000

# Email Configuration (for future features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@taskmanager.com

# File Upload (for future features)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-key

# Testing
TEST_DATABASE_URI=mongodb://localhost:27017/task-manager-test
JEST_TIMEOUT=10000

# Development
DEBUG=true
ENABLE_SWAGGER=true
ENABLE_LOGGING=true

# Production Overrides
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/task-manager
# JWT_SECRET=production-jwt-secret-key
# CLIENT_URL=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com